# Copy to .env and fill in real values. Never commit the real .env.

# Selects which config class to load: development | testing | production
FLASK_ENV=development

# Required in production. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional. Defaults to a local SQLite file when unset.
# For Postgres, set a standard postgresql:// connection string (see SQLAlchemy docs).
DATABASE_URL=
